{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/check-secrets.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/check-branch.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/verify-on-stop.sh" }
        ]
      }
    ]
  }
}
